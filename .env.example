APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Optional password for the settings modal. Default is 'bigfun_isfun'.
SYSTEM_SETTINGS_PASSWORD=bigfun_isfun

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Default: smtp (Brevo primary) or google (Gmail secondary). System settings can switch this.
MAIL_MAILER=log
MAIL_SCHEME=null

# Primary SMTP — Brevo (mailer key "smtp"). Typical relay:
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=your-login@smtp-brevo.com
# MAIL_PASSWORD=your-brevo-smtp-key
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_ENCRYPTION=tls
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Secondary SMTP — Gmail app password (mailer key "google")
MAIL_GOOGLE_HOST=smtp.gmail.com
MAIL_GOOGLE_PORT=587
MAIL_GOOGLE_ENCRYPTION=tls
MAIL_GOOGLE_USERNAME=null
MAIL_GOOGLE_PASSWORD=null

# System settings UI: optional Brevo key display name + daily send hint (not sent to Brevo API)
MAIL_BREVO_SMTP_KEY_NAME=
MAIL_BREVO_DAILY_EMAIL_USED=
MAIL_BREVO_DAILY_EMAIL_LIMIT=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
